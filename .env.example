# --- Server ---
PORT=3000

# --- AI provider: 'gemini' (free tier) or 'claude' ---
AI_PROVIDER=gemini

# --- Gemini (Google AI Studio — free tier) ---
# Key: https://aistudio.google.com/apikey
# NOTE: the FREE tier may use prompts to improve Google's models — fine for
# testing, but switch to a paid tier (or Claude) before live patient traffic (POPIA).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Claude (Anthropic) — used only if AI_PROVIDER=claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
# Sandbox number for testing; replace with your approved WhatsApp sender for the pilot.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SMS fallback (no Meta/WhatsApp needed). Set MESSAGING_CHANNEL=sms to route
# reminders + missed-call text-backs over SMS from your SA number instead.
TWILIO_SMS_FROM=+27600151104
MESSAGING_CHANNEL=whatsapp   # 'whatsapp' (default) | 'sms'

# --- WhatsApp Business API approved-template Content SIDs (HX…) ---
# Required for proactive (business-initiated) messages on the production Business
# API. Leave blank to fall back to free-form text (sandbox / 24h window). Create
# these in Twilio Content Template Builder — see docs/whatsapp-templates.md.
WA_TEMPLATE_REMINDER_48H=
WA_TEMPLATE_REMINDER_24H=
WA_TEMPLATE_REMINDER_2H=
WA_TEMPLATE_WAITLIST_OFFER=
WA_TEMPLATE_MISSED_CALL=

# --- Voice mode ---
# 'gather' = TwiML <Gather>/<Say> (works without extra onboarding)
# 'conversationrelay' = Twilio-managed WebSocket + Twilio's ElevenLabs voices
# 'mediastream' = custom pipeline: Twilio raw audio + OUR Deepgram STT + OUR ElevenLabs TTS
#   (full control, any ElevenLabs voice; needs ELEVENLABS_API_KEY + DEEPGRAM_API_KEY below)
VOICE_MODE=gather
ELEVENLABS_VOICE_ID=
PUBLIC_WS_URL=wss://www.remireception.com/ws/voice
CR_TTS_PROVIDER=ElevenLabs
CR_STT_PROVIDER=Deepgram

# --- Custom Media Streams voice pipeline (VOICE_MODE=mediastream) ---
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
PUBLIC_MEDIA_WS_URL=wss://www.remireception.com/ws/media

# --- Google Calendar (pilot calendar) ---
# Base64-encoded service-account JSON key. Share the clinic's calendar with the
# service account email, then set the calendar id below.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# --- The clinic this number serves (from the clinics table) ---
DEFAULT_CLINIC_ID=

# --- Shared secret for the ElevenLabs agent's /tools/* webhooks (recommended) ---
# Set a long random string here AND as an X-Tool-Secret header on each agent tool.
TOOLS_SHARED_SECRET=

# --- Dashboard / report access (REQUIRED to enable them) ---
# /dashboard and /report expose patient data and are FAIL-CLOSED: with no token
# set they are disabled. Use a long random value, then view with ?token=<value>.
DASHBOARD_TOKEN=

# --- Error monitoring (all optional; unset = console logging only) ---
# Sentry needs the SDK installed too: npm i @sentry/node
SENTRY_DSN=
# Any incoming-webhook URL (e.g. Slack) to receive error alerts as JSON {text}.
MONITORING_WEBHOOK_URL=

# --- Stripe deposits (off until set + a clinic has deposit_zar > 0) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://www.remireception.com/?deposit=paid

# --- Daily jobs (owner summary + reactivation) ---
DAILY_JOBS_HOUR=18

# --- Production hardening (all optional; sensible defaults) ---
RL_WEBHOOK_MAX=300        # max /webhooks/* requests per IP per minute
RL_TOOLS_MAX=60           # max /tools/* requests per IP per minute
RETENTION_DAYS=730        # POPIA: purge conversations/messages older than this

# Self-serve onboarding form (/onboard.html). Submissions require this token.
ONBOARD_TOKEN=

# Unconverted-enquiry follow-up (auto-outreach — OFF unless set to true)
FOLLOWUP_ENABLED=false
FOLLOWUP_MIN_HOURS=3
FOLLOWUP_MAX_HOURS=72
# Monthly owner report day-of-month
MONTHLY_REPORT_DAY=1
PUBLIC_BASE_URL=https://www.remireception.com

# Digital patient intake form (sent to first-time patients on booking)
INTAKE_ENABLED=false
INTAKE_SECRET=

# Morning team huddle (today's schedule to the owner)
HUDDLE_HOUR=7
