# Dashboard SPA env (Vite). Copy to .env.local for dev.
# Public values — safe in the browser (RLS + API scoping enforce access).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Where the Remi API lives. Blank = same origin (prod). For dev the Vite proxy
# forwards /api to localhost:3000, so leave blank.
VITE_API_BASE=
